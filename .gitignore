node_modules/
.env
# Next.js local env overrides (.env.local, .env.production.local, …). The bare
# `.env` above does not match these names, and the site reads them for local
# secrets. `.env.example` is tracked (public template) and does not end in
# `.local`, so it stays committed.
.env*.local
*.log
dist/
build/
.next/
.DS_Store

# Synthetic seed is rendered locally from the vendored DSL (see part 03):
data/synthetic/.build/
data/synthetic/seed_embeddings.jsonl
products/polaris/site/supabase/migrations/20250101*_seed_*.sql

# Per-service runtime data volumes
infrastructure/*/data/

# Railway CLI link state (project documented in infrastructure/railway/README.md)
.railway/
bun.lockb

# Local environment overrides (TLS proxy CA, host-specific mounts)
docker-compose.override.yml
infrastructure/tei/ca-bundle.pem
infrastructure/tei/model/
products/polaris/site/supabase/.temp/

# APM dependencies. Skill packs are pinned in apm.yml + apm.lock.yaml and
# reconstituted by `apm install`; the materialized agent/skill trees below are
# build output, not source — like node_modules.
apm_modules/
.agents/
.claude/agents/
.claude/skills/
.github/agents/

# Agent memory. wiki/ is its own git repo (github.com/forwardimpact/bionova-apps.wiki),
# hydrated and pushed by fit-wiki. It is the single authoritative ledger the merge
# gate reads. Tracking it here too forked STATUS.md into a stale shadow (issue #105);
# the app repo must not track wiki/ at all.
/wiki/
