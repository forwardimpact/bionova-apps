{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "@bionova/polaris-handlers": ["./products/polaris/handlers/src/index.js"],
      "@bionova/polaris-handlers/*": ["./products/polaris/handlers/src/*"]
    }
  },
  "comment": "The Next.js site (products/polaris/site) and the Deno edge functions own their own tsconfig/deno.json and are typechecked separately; excluded here so root `tsc --noEmit` only covers handlers + cli.",
  "exclude": [
    "node_modules",
    "**/.next",
    "**/dist",
    "data/synthetic/.build",
    "products/polaris/site",
    "services/polaris-functions"
  ]
}
