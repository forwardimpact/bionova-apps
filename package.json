{
  "name": "bionova-apps",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["products/*/cli", "products/*/site", "products/*/handlers"],
  "engines": { "node": ">=20.19.0", "bun": ">=1.2" },
  "scripts": {
    "setup": "./setup.sh",
    "seed": "bash scripts/build-seed.sh",
    "lint:js": "eslint .",
    "lint:deno": "cd services/polaris-functions && deno lint",
    "lint": "bun run lint:js && bun run lint:deno",
    "coaligned": "coaligned",
    "check": "bun run lint && bunx tsc --noEmit && coaligned",
    "test:js": "bun test products/polaris/handlers products/polaris/cli",
    "test:scripts": "bun test scripts",
    "test:site": "cd products/polaris/site && bun run test",
    "test:deno": "cd services/polaris-functions && deno test --allow-net --allow-read --allow-env",
    "test": "bun run test:js && bun run test:scripts && bun run test:site && bun run test:deno"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@eslint/js": "9.39.4",
    "@forwardimpact/libcoaligned": "^0.1.16",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "fit-terrain": "0.1.41",
    "prettier": "3.9.5"
  },
  "overrides": {
    "vite": "^6.4.3",
    "postcss": "^8.5.10"
  }
}
