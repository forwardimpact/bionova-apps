# BioNova Polaris — local environment.
# Copy to `.env` and adjust. The values below are the well-known Supabase
# self-hosted DEMO keys — public, low-entropy, scoped to your local stack only.
# Never reuse them for anything reachable from the internet.

# Signing secret shared by GoTrue + PostgREST. ANON_KEY and SERVICE_ROLE_KEY
# below are JWTs signed with exactly this secret — change one, regenerate both.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Postgres superuser password (used by setup.sh + supabase db push).
POSTGRES_PASSWORD=postgres

# anon role JWT (role=anon, iss=supabase-demo).
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.F_rDxRTPE8OU83L_CNgEGXfmirMXmMMugT29Cvc8ygQ

# service_role JWT (role=service_role) — bypasses RLS via the service_role GRANT.
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.5z-pJI1qwZg1LE5yavGLqum65WOnnaaI5eZ3V00pLww

# Realtime cookie/secret key base (>= 64 chars).
REALTIME_SECRET=super-secret-realtime-key-base-at-least-sixty-four-characters-long-xx

# MinIO (S3 backend for Storage).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# imgproxy salt/key (hex). Demo values; rotate for any shared deployment.
IMGPROXY_KEY=6465616462656566
IMGPROXY_SALT=6465616462656566

# TEI embedding model. By default the tei container downloads
# BAAI/bge-small-en-v1.5 from huggingface.co into the tei-data volume, so these
# stay unset. If your network blocks that download (e.g. a TLS-inspecting proxy
# the container does not trust), fetch the model to the host with
# `just tei-model`, then uncomment both lines below (TEI_MODEL_SOURCE is the
# path the recipe prints) so tei loads the local copy instead:
#   TEI_MODEL_ID=/data
#   TEI_MODEL_SOURCE=/absolute/path/to/bge-small-en-v1.5
